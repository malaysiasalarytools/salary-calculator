<script>
  function formatRM(value) {
    return Number(value).toLocaleString('en-MY', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });
  }

  function setIncome(value) {
    document.getElementById("income").value = value;
    document.getElementById("incomeRange").value = value;
    calculateDSR();
  }

  function calculateDSR() {
    const incomeInput = document.getElementById("income");
    const incomeRange = document.getElementById("incomeRange");

    const income = parseFloat(incomeInput.value) || 0;
    const existingDebt = parseFloat(document.getElementById("existingDebt").value) || 0;
    const newLoan = parseFloat(document.getElementById("newLoan").value) || 0;
    const creditCard = parseFloat(document.getElementById("creditCard").value) || 0;
    const otherDebt = parseFloat(document.getElementById("otherDebt").value) || 0;

    if (!income || income <= 0 || existingDebt < 0 || newLoan < 0 || creditCard < 0 || otherDebt < 0) {
      document.getElementById("dsrResult").textContent = "0.00";
      document.getElementById("dsrExplanation").textContent = "Please enter valid monthly income and debt commitments.";
      document.getElementById("dsrBar").innerHTML = "";
      document.getElementById("resultRows").innerHTML = "";
      document.getElementById("summaryRows").innerHTML = "";
      return;
    }

    incomeRange.value = Math.min(income, incomeRange.max);

    const totalDebt = existingDebt + newLoan + creditCard + otherDebt;
    const dsr = (totalDebt / income) * 100;
    const remainingIncome = income - totalDebt;
    const debtPercent = Math.min(100, dsr);
    const freePercent = Math.max(0, 100 - debtPercent);

    let status = "";
    let statusText = "";

    if (dsr < 40) {
      status = "Lower DSR";
      statusText = "Your estimated DSR is relatively low.";
    } else if (dsr <= 60) {
      status = "Moderate DSR";
      statusText = "Your estimated DSR is moderate.";
    } else {
      status = "High DSR";
      statusText = "Your estimated DSR is high.";
    }

    document.getElementById("dsrResult").textContent = dsr.toFixed(2);
    document.getElementById("dsrExplanation").textContent =
      statusText + " This is a simple estimate only.";

    document.getElementById("dsrBar").innerHTML =
      '<i style="width:' + debtPercent + '%;background:#5aa783"></i>' +
      '<i style="width:' + freePercent + '%;background:#c9a14e"></i>';

    document.getElementById("resultRows").innerHTML =
      '<div class="result-line"><span class="k"><span class="dot" style="background:#f6f3ec"></span>Monthly Income</span><span class="v">RM ' + formatRM(income) + '</span></div>' +
      '<div class="result-line"><span class="k"><span class="dot" style="background:#5aa783"></span>Existing Commitments</span><span class="v">RM ' + formatRM(existingDebt) + '</span></div>' +
      '<div class="result-line"><span class="k"><span class="dot" style="background:#2f7d5e"></span>New Loan Installment</span><span class="v">RM ' + formatRM(newLoan) + '</span></div>' +
      '<div class="result-line"><span class="k"><span class="dot" style="background:#c9a14e"></span>Total Monthly Debt</span><span class="v">RM ' + formatRM(totalDebt) + '</span></div>' +
      '<div class="result-line"><span class="k"><span class="dot" style="background:#cf6f5b"></span>DSR Status</span><span class="v">' + status + '</span></div>';

    document.getElementById("summaryRows").innerHTML =
      '<div><span>Formula Used</span><strong>Total debt ÷ income × 100%</strong></div>' +
      '<div><span>Credit Card Minimum Payment</span><strong>RM ' + formatRM(creditCard) + '</strong></div>' +
      '<div><span>Other Monthly Debt</span><strong>RM ' + formatRM(otherDebt) + '</strong></div>' +
      '<div><span>Remaining Income After Debt</span><strong>RM ' + formatRM(remainingIncome) + '</strong></div>';
  }

  document.getElementById("income").addEventListener("input", calculateDSR);
  document.getElementById("incomeRange").addEventListener("input", function() {
    document.getElementById("income").value = this.value;
    calculateDSR();
  });
  document.getElementById("existingDebt").addEventListener("input", calculateDSR);
  document.getElementById("newLoan").addEventListener("input", calculateDSR);
  document.getElementById("creditCard").addEventListener("input", calculateDSR);
  document.getElementById("otherDebt").addEventListener("input", calculateDSR);

  calculateDSR();
</script>

